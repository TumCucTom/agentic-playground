{
  "name": "canvas-workspace",
  "version": "0.1.0",
  "description": "Infinite-canvas macOS app hosting VS Code panels and built-in tools",
  "main": "dist/main/index.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "dev:preload": "tsc -p tsconfig.preload.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on http://localhost:5173 && wait-on dist/main/index.js dist/preload/index.js && electron .",
    "dev": "concurrently -k -n vite,main,preload,electron -c blue,green,yellow,magenta \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:preload\" \"npm:dev:electron\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:extensions": "mkdir -p dist && cp -R bundled-extensions dist/ 2>/dev/null || true",
    "build": "npm run build:renderer && npm run build:main && npm run build:preload && npm run build:extensions",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "package:mac": "electron-packager . CanvasWorkspace --platform=darwin --arch=arm64 --out=release --overwrite --app-bundle-id=com.canvasworkspace.app --app-version=0.1.0 --ignore=\"^/tests\" --ignore=\"^/release\" --ignore=\"^/test-results\" --ignore=\"^/playwright-report\" --ignore=\"^/\\\\.git\" --ignore=\"^/docs\" --ignore=\"^/src\" --ignore=\"^/tsconfig\" --ignore=\"\\\\.tsbuildinfo\" --ignore=\"^/playwright\\\\.config\\\\.ts$\" --ignore=\"^/vitest\\\\.config\\\\.ts$\" --ignore=\"^/vite\\\\.config\\\\.ts$\""
  },
  "author": "Thomas Bale",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-packager": "^17.1.2",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "monaco-editor": "^0.45.0",
    "node-pty": "^1.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^4.4.0"
  }
}
